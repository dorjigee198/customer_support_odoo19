<odoo>
    <template id="portal_login_page" name="Customer Support Login">
        <t t-call="web.layout">
            <t t-set="head">
                <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no"/>
                <!--  Bootstrap 5 CSS  -->
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet"/>
                <!--  Custom CSS  -->
                <link rel="stylesheet" href="/customer_support/static/src/css/portal_login.css"/>
            </t>

            <div class="login-container container-fluid p-0">
                <div class="row g-0">

                    <!--  Left Section - Illustration  -->
                    <div class="left-section col-lg-6 d-flex align-items-stretch d-none d-lg-flex">
                        <div class="illustration-container w-100">
                            <!--  Background Pattern  -->
                            <div class="background-pattern"/>
                            <!--  Floating Elements  -->
                            <div class="floating-elements-container">
                                <div class="floating-element">
                                    <i class="bi bi-envelope-fill"/>
                                </div>
                                <div class="floating-element">
                                    <i class="bi bi-check-circle-fill"/>
                                </div>
                                <div class="floating-element">
                                    <i class="bi bi-chat-dots-fill"/>
                                </div>
                            </div>
                            <!--  Character Image with Shadow  -->
                            <div class="character-illustration-container">
                                <!--  Shadow  -->
                                <div class="character-shadow"/>
                                <!--  Your Image  -->
                                <img src="/customer_support/static/src/img/girl.png" alt="Character" class="character-image"/>
                            </div>
                        </div>
                    </div>

                    <!--  Right Section - Login Form  -->
                    <div class="right-section col-12 col-lg-6 d-flex align-items-stretch">
                        <div class="background-overlay"/>
                        <div class="login-form-container w-100">
                            <div class="login-box">

                                <!--  Logo  -->
                                <div class="logo-section">
                                    <div class="logo-container">
                                        <div class="logo-circle">
                                            <img src="/customer_support/static/src/img/images.png" alt="Logo" class="logo-img"/>
                                        </div>
                                    </div>
                                    <h2 class="login-title">Login to your account</h2>
                                </div>

                                <!--  Error Message  -->
                                <div class="error-message" t-if="error">
                                    <t t-esc="error"/>
                                </div>

                                <!--  Login Form  -->
                                <form action="/customer_support/authenticate" method="post">

                                    <!-- ← ADDED: passes the redirect URL through the form so
                                         after login the customer lands back on their ticket -->
                                    <input type="hidden" name="redirect" t-att-value="redirect or ''"/>

                                    <!--  Email Input  -->
                                    <div class="input-group-custom">
                                        <label for="email" class="form-label">Email Address</label>
                                        <div class="position-relative">
                                            <input type="email" id="email" name="email"
                                                class="form-control form-control-custom ps-5"
                                                placeholder="Enter your email"
                                                required="required"
                                                autocomplete="email"/>
                                            <i class="bi bi-envelope-fill input-icon"/>
                                        </div>
                                    </div>

                                    <!--  Password Input  -->
                                    <div class="input-group-custom">
                                        <label for="password" class="form-label">Password</label>
                                        <div class="position-relative">
                                            <input type="password" id="password" name="password"
                                                class="form-control form-control-custom ps-5"
                                                placeholder="Enter your password"
                                                required="required"
                                                autocomplete="current-password"/>
                                            <i class="bi bi-lock-fill input-icon"/>
                                            <button type="button" class="password-toggle-btn" onclick="togglePassword()">
                                                <i class="bi bi-eye-fill"/>
                                            </button>
                                        </div>
                                    </div>

                                    <!--  Forgot/Reset Links  -->
                                    <div class="login-links">
                                        <a href="/web/reset_password" class="text-decoration-none">Forgot password?</a>
                                        <a href="/web/reset_password" class="text-decoration-none">Reset password</a>
                                    </div>

                                    <!--  Submit Button  -->
                                    <button type="submit" class="submit-btn">
                                        <span>Sign in</span>
                                    </button>

                                </form>
                            </div>
                        </div>
                    </div>

                </div>
            </div>

            <!--  Bootstrap JS Bundle  -->
            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"/>
            <!--  Custom JavaScript  -->
            <script src="/customer_support/static/src/js/portal_login.js"/>
            <script>
                // bfcache guard: reload if browser restores this page while authenticated
                window.addEventListener('pageshow', function (e) {
                    if (e.persisted) { window.location.reload(); }
                });
                // popstate guard: if back/forward navigates outside the portal
                // (e.g. to /web/login), redirect to the landing page
                window.addEventListener('popstate', function () {
                    if (!window.location.pathname.startsWith('/customer_support/')) {
                        window.location.replace('/customer_support/');
                    }
                });
            </script>

        </t>
    </template>
</odoo>

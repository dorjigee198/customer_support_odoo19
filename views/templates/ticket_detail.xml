<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="ticket_detail" name="Ticket Details">
        <t t-call="web.layout">
            <t t-set="head">
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet"/>
                <link href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" rel="stylesheet"/>
                <link rel="stylesheet" href="/customer_support/static/src/css/support_dashboard.css"/>
                <link rel="stylesheet" href="/customer_support/static/src/css/ticket_details.css"/>
                <link rel="stylesheet" href="/customer_support/static/src/css/customer_ticket_details.css"/>
                
                <style>
                    .message-actions { opacity: 0; visibility: hidden; transition: opacity 0.2s ease, visibility 0.2s ease; }
                    .message-item:hover .message-actions { opacity: 1; visibility: visible; }
                    .message-action-btn { background: none; border: none; padding: 6px 10px; border-radius: 4px; cursor: pointer; font-size: 14px; transition: all 0.2s ease; margin-left: 4px; }
                    .edit-message-btn   { color: #6c757d; }
                    .edit-message-btn:hover   { background-color: #0d6efd; color: white; }
                    .delete-message-btn { color: #6c757d; }
                    .delete-message-btn:hover { background-color: #dc3545; color: white; }
                    .message-header { display: flex; align-items: center; justify-content: space-between; gap: 10px; }
                    .message-time  { margin-left: auto; white-space: nowrap; }
                    .message-actions { display: flex; align-items: center; margin-left: 8px; }

                    .sla-timer-card { border-radius: 16px; padding: 1.25rem; margin-bottom: 1.25rem; position: relative; overflow: hidden; transition: border-color 0.3s, background 0.3s; }
                    .sla-timer-card.on-track { border: 1px solid rgba(34,197,94,0.35); background: linear-gradient(145deg, rgba(34,197,94,0.07), #161b27); }
                    .sla-timer-card.at-risk  { border: 1px solid rgba(245,158,11,0.45); background: linear-gradient(145deg, rgba(245,158,11,0.08), #161b27); }
                    .sla-timer-card.breached { border: 1px solid rgba(239,68,68,0.5);   background: linear-gradient(145deg, rgba(239,68,68,0.1), #161b27); animation: sla-pulse 2.5s infinite; }
                    .sla-timer-card.no-sla   { border: 1px solid rgba(255,255,255,0.07); background: #161b27; }
                    @keyframes sla-pulse { 0%, 100% { box-shadow: 0 0 0 0 rgba(239,68,68,0.25); } 50% { box-shadow: 0 0 0 10px rgba(239,68,68,0); } }

                    .sla-card-header { display: flex; align-items: center; gap: 0.6rem; margin-bottom: 0.9rem; padding-bottom: 0.75rem; border-bottom: 1px solid rgba(255,255,255,0.07); }
                    .sla-card-icon { font-size: 1rem; }
                    .sla-timer-card.on-track .sla-card-icon { color: #22c55e; }
                    .sla-timer-card.at-risk   .sla-card-icon { color: #f59e0b; }
                    .sla-timer-card.breached  .sla-card-icon { color: #ef4444; }
                    .sla-timer-card.no-sla    .sla-card-icon { color: #8892a4; }
                    .sla-card-title { font-size: 0.875rem; font-weight: 600; color: #e8eaf0; flex: 1; }
                    .sla-policy-chip { font-size: 0.68rem; color: #8892a4; background: #1e2535; border: 1px solid rgba(255,255,255,0.07); padding: 3px 8px; border-radius: 5px; white-space: nowrap; }
                    .sla-countdown-wrap { text-align: center; padding: 1rem 0 0.6rem; }
                    .sla-big-number { font-family: 'JetBrains Mono', 'Courier New', monospace; font-size: 2.4rem; font-weight: 700; line-height: 1; letter-spacing: -0.03em; }
                    .sla-timer-card.on-track .sla-big-number { color: #22c55e; }
                    .sla-timer-card.at-risk   .sla-big-number { color: #f59e0b; }
                    .sla-timer-card.breached  .sla-big-number { color: #ef4444; }
                    .sla-timer-card.no-sla    .sla-big-number { color: #8892a4; }
                    .sla-big-label { font-size: 0.72rem; color: #8892a4; margin-top: 0.35rem; text-transform: uppercase; letter-spacing: 0.05em; }
                    .sla-progress-section { margin-top: 0.9rem; }
                    .sla-prog-meta { display: flex; justify-content: space-between; font-size: 0.7rem; color: #8892a4; margin-bottom: 0.35rem; }
                    .sla-prog-track { background: rgba(255,255,255,0.07); border-radius: 999px; height: 6px; overflow: hidden; }
                    .sla-prog-fill  { height: 6px; border-radius: 999px; transition: width 0.8s ease; }
                    .sla-timer-card.on-track .sla-prog-fill { background: linear-gradient(90deg,#16a34a,#22c55e); }
                    .sla-timer-card.at-risk   .sla-prog-fill { background: linear-gradient(90deg,#d97706,#f59e0b); }
                    .sla-timer-card.breached  .sla-prog-fill { background: linear-gradient(90deg,#b91c1c,#ef4444); }
                    .sla-deadline-row { display: flex; justify-content: space-between; align-items: center; margin-top: 0.9rem; padding-top: 0.75rem; border-top: 1px solid rgba(255,255,255,0.07); font-size: 0.75rem; }
                    .sla-deadline-label { color: #8892a4; }
                    .sla-deadline-val   { color: #e8eaf0; font-weight: 500; }
                </style>
            </t>

            <div class="dashboard-wrapper">

                <div class="page-content ticket-detail-content">
                    <div class="ticket-detail-container">

                        <div class="ticket-main-column">
                            <div class="mb-3">
                                <a href="/customer_support/support_dashboard" class="btn btn-outline-primary">
                                    <i class="bi bi-arrow-left me-2"></i>Back to Dashboard
                                </a>
                            </div>

                            <div class="info-banner">
                                <i class="bi bi-lock-fill"></i>
                                <div class="info-text">
                                    <strong>Ticket Information Locked</strong>
                                    <p>This ticket's details are read-only and cannot be edited once created. You can only add comments in the Communication section below.</p>
                                </div>
                            </div>

                            <div class="alert alert-success alert-dismissible fade show notification-alert" t-if="success">
                                <i class="bi bi-check-circle-fill"></i>
                                <strong>Success!</strong> <t t-esc="success"/>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>
                            <div class="alert alert-danger alert-dismissible fade show notification-alert" t-if="error">
                                <i class="bi bi-exclamation-triangle-fill"></i>
                                <strong>Error!</strong> <t t-esc="error"/>
                                <button type="button" class="btn-close" data-bs-dismiss="alert"></button>
                            </div>

                            <div class="ticket-header-card">
                                <div class="ticket-id-badges">
                                    <span class="ticket-id-badge"><t t-esc="ticket.name"/></span>

                                    <t t-set="priority_class" t-value="''" />
                                    <t t-if="ticket.priority == 'low'"><t t-set="priority_class" t-value="'priority-low'" /></t>
                                    <t t-elif="ticket.priority == 'medium'"><t t-set="priority_class" t-value="'priority-medium'" /></t>
                                    <t t-elif="ticket.priority == 'high'"><t t-set="priority_class" t-value="'priority-high'" /></t>
                                    <t t-elif="ticket.priority == 'urgent'"><t t-set="priority_class" t-value="'priority-urgent'" /></t>
                                    <span t-att-class="'priority-badge ' + priority_class">
                                        <t t-esc="ticket.priority.title() if ticket.priority else 'Low'" />
                                    </span>

                                    <t t-set="state_class" t-value="''" />
                                    <t t-if="ticket.state == 'new'"><t t-set="state_class" t-value="'state-new'" /></t>
                                    <t t-elif="ticket.state == 'in_progress'"><t t-set="state_class" t-value="'state-progress'" /></t>
                                    <t t-elif="ticket.state == 'resolved'"><t t-set="state_class" t-value="'state-resolved'" /></t>
                                    <t t-elif="ticket.state == 'closed'"><t t-set="state_class" t-value="'state-closed'" /></t>
                                    <span t-att-class="'state-badge ' + state_class">
                                        <t t-esc="ticket.state.replace('_', ' ').title()" />
                                    </span>
                                </div>

                                <h1 class="ticket-title"><t t-esc="ticket.subject"/></h1>

                                <div class="ticket-meta-info">
                                    <span class="meta-item">
                                        <i class="bi bi-person"></i>
                                        Created by <t t-esc="ticket.customer_id.name if ticket.customer_id else 'Unknown'" />
                                    </span>
                                    <span class="meta-divider">•</span>
                                    <span class="meta-item">
                                        <i class="bi bi-calendar"></i>
                                        <t t-esc="ticket.create_date.strftime('%B %d, %Y at %I:%M %p') if ticket.create_date else 'N/A'"/>
                                    </span>
                                </div>

                                <div class="ticket-description">
                                    <t t-if="ticket.description">
                                        <t t-esc="ticket.description" />
                                    </t>
                                    <t t-else="">
                                        <p class="text-muted">No description provided.</p>
                                    </t>
                                </div>
                            </div>

                            <!-- Attachments Section -->
                            <div class="communication-section">
                                <div class="section-header">
                                    <i class="bi bi-paperclip"></i>
                                    <h3>Attached Files</h3>
                                </div>
                                <div class="communication-messages">
                                    <t t-if="attachments">
                                        <div class="row g-3">
                                            <t t-foreach="attachments" t-as="attach">
                                                <div class="col-sm-6">
                                                    <div class="p-2 border rounded d-flex align-items-center justify-content-between bg-white">
                                                        <div class="text-truncate me-2">
                                                            <i class="bi bi-file-earmark-text text-primary me-2"></i>
                                                            <span class="small" t-esc="attach.name"/>
                                                        </div>
                                                        <a t-attf-href="/web/content/#{attach.id}?download=true&amp;access_token=#{attach.access_token}"
                                                           class="btn btn-sm btn-primary shadow-sm"
                                                           target="_blank">
                                                            <i class="bi bi-download me-1"></i>Download
                                                        </a>
                                                    </div>
                                                </div>
                                            </t>
                                        </div>
                                    </t>
                                    <t t-else="">
                                        <div class="empty-state">
                                            <i class="bi bi-paperclip"></i>
                                            <p>No attachments found for this ticket.</p>
                                        </div>
                                    </t>
                                </div>
                            </div>

                            <!-- Communication Section -->
                            <div class="communication-section">
                                <div class="section-header">
                                    <i class="bi bi-chat-left-text-fill"></i>
                                    <h3>Communication</h3>
                                </div>

                                <div class="communication-messages" id="communicationMessages">
                                    <t t-if="activities and len(activities) > 0">
                                        <t t-foreach="activities" t-as="activity">
                                            <t t-set="is_author" t-value="activity.author_id.id == request.env.user.partner_id.id if activity.author_id else False" />
                                            <t t-set="is_admin" t-value="request.env.user.has_group('base.group_system')" />
                                            <div class="message-item" t-att-data-message-id="activity.id">
                                                <t t-set="author_id" t-value="activity.author_id.id if activity.author_id else request.env.user.partner_id.id" />
                                                <img t-att-src="'/web/image/res.partner/%s/avatar_128' % author_id"
                                                    alt="Avatar" class="message-avatar"
                                                    onerror="this.src='/web/static/img/avatar_gray.svg'" />
                                                <div class="message-content">
                                                    <div class="message-header">
                                                        <strong><t t-esc="activity.author_id.name if activity.author_id else 'System'" /></strong>
                                                        <span class="message-time">
                                                            <t t-if="activity.date">
                                                                <t t-esc="activity.date.strftime('%B %d, %Y at %I:%M %p')" />
                                                            </t>
                                                            <t t-else="">Recently</t>
                                                        </span>
                                                        <div class="message-actions">
                                                            <t t-if="is_author">
                                                                <button class="message-action-btn edit-message-btn"
                                                                    t-att-data-message-id="activity.id" title="Edit message">
                                                                    <i class="bi bi-pencil"></i>
                                                                </button>
                                                            </t>
                                                            <t t-if="is_author or is_admin">
                                                                <button class="message-action-btn delete-message-btn"
                                                                    t-att-data-message-id="activity.id" title="Delete message">
                                                                    <i class="bi bi-trash"></i>
                                                                </button>
                                                            </t>
                                                        </div>
                                                    </div>
                                                    <div class="message-body" t-att-data-message-id="activity.id">
                                                        <t t-if="activity.body"><t t-raw="activity.body" /></t>
                                                        <t t-else=""><em class="text-muted">[Empty message]</em></t>
                                                    </div>
                                                    <div class="message-edit-form" t-att-data-message-id="activity.id" style="display: none;">
                                                        <textarea class="form-control edit-message-textarea" rows="3"
                                                            t-att-data-original-body="activity.body">
                                                            <t t-esc="activity.body" />
                                                        </textarea>
                                                        <div class="edit-form-actions mt-2">
                                                            <button class="btn btn-sm btn-primary save-edit-btn" t-att-data-message-id="activity.id">
                                                                <i class="bi bi-check"></i> Save
                                                            </button>
                                                            <button class="btn btn-sm btn-secondary cancel-edit-btn" t-att-data-message-id="activity.id">
                                                                <i class="bi bi-x"></i> Cancel
                                                            </button>
                                                        </div>
                                                    </div>
                                                </div>
                                            </div>
                                        </t>
                                    </t>
                                    <t t-else="">
                                        <div class="empty-state">
                                            <i class="bi bi-chat-left-text"></i>
                                            <p>No messages yet.</p>
                                        </div>
                                    </t>
                                </div>

                                <div class="message-input-section">
                                    <form t-attf-action="/customer_support/ticket/{{ticket.id}}/post_message" method="post" id="communicationForm">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <textarea class="form-control message-textarea" name="message" id="messageTextarea"
                                            rows="3" placeholder="Type your message..." required="required"></textarea>
                                        <button type="submit" class="btn btn-send">
                                            <i class="bi bi-send-fill"></i> Send
                                        </button>
                                    </form>
                                </div>
                            </div>
                        </div>

                        <!-- ── Right Sidebar ── -->
                        <div class="ticket-sidebar-column">

                            <!-- ══ SLA TIMER CARD — active ticket with policy + deadline ══ -->
                            <t t-if="ticket.sla_policy_id and ticket.sla_deadline and ticket.state not in ['resolved','closed']">
                                <div class="sla-timer-card on-track" id="slaTimerCard"
                                    t-att-data-deadline="ticket.sla_deadline.isoformat()"
                                    t-att-data-policy="ticket.sla_policy_id.name"
                                    t-att-data-duration="ticket.sla_policy_id.response_time * 3600 if ticket.sla_policy_id.time_unit == 'hours' else (ticket.sla_policy_id.response_time * 604800 if ticket.sla_policy_id.time_unit == 'weeks' else ticket.sla_policy_id.response_time * 86400)">

                                    <div class="sla-card-header">
                                        <i class="bi bi-clock-fill sla-card-icon" id="slaIcon"></i>
                                        <span class="sla-card-title" id="slaCardTitle">SLA On Track</span>
                                        <span class="sla-policy-chip"><t t-esc="ticket.sla_policy_id.name" /></span>
                                    </div>

                                    <div class="sla-countdown-wrap">
                                        <div class="sla-big-number" id="slaBigNumber">00:00:00</div>
                                        <div class="sla-big-label" id="slaBigLabel">remaining</div>
                                    </div>

                                    <div class="sla-progress-section">
                                        <div class="sla-prog-meta">
                                            <span>Time elapsed</span>
                                            <span id="slaProgPct">0%</span>
                                        </div>
                                        <div class="sla-prog-track">
                                            <div class="sla-prog-fill" id="slaProgFill" style="width: 0%"></div>
                                        </div>
                                    </div>

                                    <div class="sla-deadline-row">
                                        <span class="sla-deadline-label">Deadline</span>
                                        <span class="sla-deadline-val" id="slaDeadlineVal">
                                            <t t-esc="ticket.sla_deadline.strftime('%b %d, %I:%M %p') if ticket.sla_deadline else '—'" />
                                        </span>
                                    </div>
                                </div>
                            </t>

                            <!-- ══ SLA RESULT — resolved/closed ticket ══ -->
                            <t t-elif="ticket.sla_policy_id and ticket.state in ['resolved','closed']">
                                <div class="sla-timer-card no-sla">
                                    <div class="sla-card-header">
                                        <t t-if="ticket.sla_status == 'breached'">
                                            <i class="bi bi-x-octagon-fill sla-card-icon" style="color:#ef4444;"></i>
                                            <span class="sla-card-title" style="color:#ef4444;">SLA Breached</span>
                                        </t>
                                        <t t-else="">
                                            <i class="bi bi-check-circle-fill sla-card-icon" style="color:#22c55e;"></i>
                                            <span class="sla-card-title" style="color:#22c55e;">SLA Met</span>
                                        </t>
                                        <span class="sla-policy-chip"><t t-esc="ticket.sla_policy_id.name" /></span>
                                    </div>
                                    <div class="sla-countdown-wrap">
                                        <div class="sla-big-number" style="font-size:1.2rem;color:#8892a4;">Ticket Closed</div>
                                        <div class="sla-big-label">No active timer</div>
                                    </div>
                                </div>
                            </t>

                            <!-- ══ NO SLA — no policy assigned ══ -->
                            <t t-else="">
                                <div class="sla-timer-card no-sla">
                                    <div class="sla-card-header">
                                        <i class="bi bi-clock sla-card-icon"></i>
                                        <span class="sla-card-title">No SLA Assigned</span>
                                    </div>
                                    <div class="sla-countdown-wrap">
                                        <div class="sla-big-number" style="font-size:1.1rem;color:#8892a4;">—</div>
                                        <div class="sla-big-label">No policy attached</div>
                                    </div>
                                </div>
                            </t>

                            <!-- Properties Card -->
                            <div class="properties-card">
                                <div class="card-header-custom">
                                    <i class="bi bi-gear-fill"></i>
                                    <h3>Properties</h3>
                                </div>
                                <div class="property-item">
                                    <label class="property-label">Status</label>
                                    <form t-attf-action="/customer_support/ticket/{{ticket.id}}/update_status" method="post" class="status-form">
                                        <input type="hidden" name="csrf_token" t-att-value="request.csrf_token()"/>
                                        <select class="form-select status-select" name="status" onchange="this.form.submit()">
                                            <option value="new"         t-att-selected="'selected' if ticket.state == 'new' else None">New</option>
                                            <option value="in_progress" t-att-selected="'selected' if ticket.state == 'in_progress' else None">In Progress</option>
                                            <option value="resolved"    t-att-selected="'selected' if ticket.state == 'resolved' else None">Resolved</option>
                                            <option value="closed"      t-att-selected="'selected' if ticket.state == 'closed' else None">Closed</option>
                                        </select>
                                    </form>
                                </div>
                                <div class="property-item">
                                    <label class="property-label">Priority</label>
                                    <button t-att-class="'priority-button ' + priority_class" disabled="disabled">
                                        <t t-esc="ticket.priority.title() if ticket.priority else 'Low'" />
                                    </button>
                                </div>
                                <div class="property-item">
                                    <label class="property-label">Assignee</label>
                                    <div class="assignee-info">
                                        <img t-att-src="'/web/image/res.users/%s/avatar_128' % (ticket.assigned_to.id if ticket.assigned_to else request.env.user.id)"
                                            alt="Assignee Avatar" class="assignee-avatar"
                                            onerror="this.src='/web/static/img/avatar_gray.svg'" />
                                        <div class="assignee-details">
                                            <strong>
                                                <t t-if="ticket.assigned_to"><t t-esc="ticket.assigned_to.name" /></t>
                                                <t t-else="">Not assigned</t>
                                            </strong>
                                            <span class="assignee-email">
                                                <t t-if="ticket.assigned_to and ticket.assigned_to.email">
                                                    <t t-esc="ticket.assigned_to.email" />
                                                </t>
                                            </span>
                                        </div>
                                    </div>
                                </div>
                            </div>

                            <!-- Customer Information Card -->
                            <div class="info-card">
                                <div class="card-header-custom"><h3>Customer Information</h3></div>
                                <div class="customer-info">
                                    <img t-att-src="'/web/image/res.partner/%s/avatar_128' % (ticket.customer_id.id if ticket.customer_id else 1)"
                                        alt="Customer Avatar" class="customer-avatar"
                                        onerror="this.src='/web/static/img/avatar_gray.svg'" />
                                    <div class="customer-details">
                                        <strong><t t-esc="ticket.customer_id.name if ticket.customer_id else 'Unknown Customer'" /></strong>
                                        <span class="customer-email">
                                            <t t-if="ticket.customer_id and ticket.customer_id.email">
                                                <t t-esc="ticket.customer_id.email" />
                                            </t>
                                            <t t-else="">No email</t>
                                        </span>
                                    </div>
                                </div>
                            </div>

                            <!-- Projects Card -->
                            <t t-if="ticket.project_id">
                                <div class="info-card">
                                    <div class="card-header-custom">
                                        <i class="bi bi-folder-fill"></i>
                                        <h3>Project</h3>
                                    </div>
                                    <div class="project-info-detail">
                                        <div class="project-name">
                                            <t t-esc="ticket.project_id.name if ticket.project_id else 'No Project'" />
                                        </div>
                                    </div>
                                </div>
                            </t>
                        </div>
                    </div>
                </div>
            </div>

            <!-- Delete Modal -->
            <div class="modal fade" id="deleteMessageModal" tabindex="-1">
                <div class="modal-dialog modal-dialog-centered">
                    <div class="modal-content">
                        <div class="modal-header">
                            <h5 class="modal-title">
                                <i class="bi bi-exclamation-triangle-fill text-warning me-2"></i>Confirm Delete
                            </h5>
                            <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                        </div>
                        <div class="modal-body">
                            <p>Are you sure you want to delete this message? This action cannot be undone.</p>
                        </div>
                        <div class="modal-footer">
                            <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cancel</button>
                            <button type="button" class="btn btn-danger" id="confirmDeleteBtn">
                                <i class="bi bi-trash"></i> Delete Message
                            </button>
                        </div>
                    </div>
                </div>
            </div>

            <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>

            <script type="text/javascript">
//<![CDATA[
(function () {
    'use strict';
    var card = document.getElementById('slaTimerCard');
    if (!card) return;

    var deadlineStr = card.getAttribute('data-deadline');
    var duration    = parseInt(card.getAttribute('data-duration'), 10) * 1000;
    var deadline    = new Date(deadlineStr).getTime();

    var iconEl  = document.getElementById('slaIcon');
    var titleEl = document.getElementById('slaCardTitle');
    var numEl   = document.getElementById('slaBigNumber');
    var lblEl   = document.getElementById('slaBigLabel');
    var fillEl  = document.getElementById('slaProgFill');
    var pctEl   = document.getElementById('slaProgPct');

    var ICON  = { 'on-track': 'bi-clock-fill', 'at-risk': 'bi-exclamation-triangle-fill', 'breached': 'bi-x-octagon-fill' };
    var TITLE = { 'on-track': 'SLA On Track',  'at-risk': 'SLA At Risk ⚠️',               'breached': 'SLA Breached!'     };

    function pad(n) { return String(n).padStart(2, '0'); }

    function getSlaClass(rem) {
        if (rem <= 0)           return 'breached';
        if (rem <= 2 * 3600000) return 'at-risk';
        return 'on-track';
    }

    function tick() {
        var now = Date.now();
        var rem = deadline - now;
        var cls = getSlaClass(rem);

        card.className = 'sla-timer-card ' + cls;
        iconEl.className   = 'bi ' + ICON[cls] + ' sla-card-icon';
        titleEl.textContent = TITLE[cls];

        if (rem <= 0) {
            var over = Math.abs(rem);
            var oh = Math.floor(over / 3600000);
            var om = Math.floor((over % 3600000) / 60000);
            var os = Math.floor((over % 60000) / 1000);
            numEl.textContent = (oh > 0 ? pad(oh) + ':' : '') + pad(om) + ':' + pad(os);
            lblEl.textContent = 'past deadline';
        } else {
            var h = Math.floor(rem / 3600000);
            var m = Math.floor((rem % 3600000) / 60000);
            var s = Math.floor((rem % 60000) / 1000);
            numEl.textContent = pad(h) + ':' + pad(m) + ':' + pad(s);
            lblEl.textContent = 'remaining';
        }

        var elapsed = duration - rem;
        var pct = Math.min(100, Math.max(0, Math.round(elapsed / duration * 100)));
        fillEl.style.width = pct + '%';
        pctEl.textContent  = pct + '%';
    }

    tick();
    setInterval(tick, 1000);
})();
//]]>
            </script>


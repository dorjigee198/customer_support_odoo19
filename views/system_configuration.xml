<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="system_configuration_template" name="System Configuration">
        <t t-call="web.layout">
            <t t-set="head">
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
                    rel="stylesheet" />
                <link rel="stylesheet"
                    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css" />
                <link
                    href="https://fonts.googleapis.com/css2?family=Sora:wght@400;500;600;700&amp;family=JetBrains+Mono:wght@400;500&amp;display=swap"
                    rel="stylesheet" />
                <link rel="stylesheet"
                    href="/customer_support/static/src/css/project_configuration.css" />
            </t>

            <div id="wrap" class="oe_structure">
                <div class="pc-page">

                    <!-- Page Header -->
                    <div class="pc-header">
                        <div class="pc-header-icon">
                            <i class="bi bi-grid-1x2-fill"></i>
                        </div>
                        <div>
                            <h1 class="pc-title">Project Configuration</h1>
                            <p class="pc-subtitle">Define project details, tech stack, and warranty
                                coverage</p>
                        </div>
                    </div>

                    <!-- Alerts -->
                    <t t-if="request.params.get('project_created')">
                        <div class="pc-alert pc-alert-success">
                            <i class="bi bi-check-circle-fill"></i>
                            <span>Project created successfully.</span>
                            <button class="pc-alert-close" onclick="this.parentElement.remove()">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    </t>
                    <t t-if="request.params.get('project_updated')">
                        <div class="pc-alert pc-alert-success">
                            <i class="bi bi-check-circle-fill"></i>
                            <span>Project updated successfully.</span>
                            <button class="pc-alert-close" onclick="this.parentElement.remove()">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    </t>
                    <t t-if="request.params.get('error')">
                        <div class="pc-alert pc-alert-danger">
                            <i class="bi bi-exclamation-triangle-fill"></i>
                            <span>
                                <t t-esc="request.params.get('error_msg', 'An error occurred.')" />
                            </span>
                            <button class="pc-alert-close" onclick="this.parentElement.remove()">
                                <i class="bi bi-x"></i>
                            </button>
                        </div>
                    </t>

                    <!-- Main Form Card -->
                    <div class="pc-card">
                        <div class="pc-card-header">
                            <i class="bi bi-folder-plus"></i>
                            <div>
                                <div class="pc-card-title">New Project</div>
                                <div class="pc-card-subtitle">Fill in the details below to register
                                    a new project</div>
                            </div>
                        </div>

                        <form id="projectConfigForm" method="post"
                            action="/customer_support/admin_dashboard/projects/create"
                            class="pc-form" novalidate="novalidate">
                            <input type="hidden" name="csrf_token"
                                t-att-value="request.csrf_token()" />

                            <!-- Section 1: Basic Information -->
                            <div class="pc-section">
                                <div class="pc-section-label">
                                    <i class="bi bi-info-circle"></i> Basic Information </div>
                                <div class="pc-grid-2">
                                    <div class="pc-field pc-span-2">
                                        <label class="pc-label" for="project_name">Project Name <span
                                                class="pc-required">*</span></label>
                                        <input type="text" class="pc-input" id="project_name"
                                            name="project_name"
                                            placeholder="e.g. Customer Portal v2"
                                            required="required" />
                                    </div>
                                    <div class="pc-field">
                                        <label class="pc-label" for="project_key">Project Key <span
                                                class="pc-required">*</span></label>
                                        <input type="text" class="pc-input pc-mono" id="project_key"
                                            name="project_key"
                                            placeholder="e.g. CP-2024" pattern="[A-Za-z0-9-]+"
                                            required="required" />
                                        <span class="pc-hint">Short unique identifier —
                                            auto-uppercased</span>
                                    </div>
                                    <div class="pc-field">
                                        <label class="pc-label" for="project_type">Project Type <span
                                                class="pc-required">*</span></label>
                                        <select class="pc-select" id="project_type"
                                            name="project_type" required="required">
                                            <option value="">Select type...</option>
                                            <option value="web_app">Web Application</option>
                                            <option value="mobile">Mobile Application</option>
                                            <option value="machine_learning">Machine Learning</option>
                                            <option value="iot">IoT Platform</option>
                                            <option value="api">API / Backend Service</option>
                                            <option value="other">Other</option>
                                        </select>
                                    </div>
                                    <div class="pc-field pc-span-2">
                                        <label class="pc-label" for="project_goals">Goals &amp;
                                            Objectives</label>
                                        <textarea class="pc-input pc-textarea" id="project_goals"
                                            name="project_goals"
                                            placeholder="Describe the project's purpose and expected outcomes..."></textarea>
                                    </div>
                                </div>
                            </div>

                            <!-- Section 2: Technology Stack -->
                            <div class="pc-section">
                                <div class="pc-section-label">
                                    <i class="bi bi-code-slash"></i> Technology Stack </div>
                                <div class="pc-grid-3">
                                    <div class="pc-field">
                                        <label class="pc-label" for="programming_languages">Programming
                                            Language</label>
                                        <select class="pc-select" id="programming_languages"
                                            name="programming_languages">
                                            <option value="">Select language...</option>
                                            <option value="python">Python</option>
                                            <option value="javascript">JavaScript</option>
                                            <option value="typescript">TypeScript</option>
                                            <option value="java">Java</option>
                                            <option value="csharp">C#</option>
                                            <option value="cpp">C++</option>
                                            <option value="go">Go</option>
                                            <option value="rust">Rust</option>
                                            <option value="php">PHP</option>
                                            <option value="ruby">Ruby</option>
                                            <option value="swift">Swift</option>
                                            <option value="kotlin">Kotlin</option>
                                            <option value="other">Other</option>
                                        </select>
                                    </div>
                                    <div class="pc-field">
                                        <label class="pc-label" for="frameworks">Framework</label>
                                        <select class="pc-select" id="frameworks" name="frameworks">
                                            <option value="">Select framework...</option>
                                            <optgroup label="Frontend">
                                                <option value="react">React</option>
                                                <option value="vue">Vue.js</option>
                                                <option value="angular">Angular</option>
                                                <option value="svelte">Svelte</option>
                                                <option value="nextjs">Next.js</option>
                                            </optgroup>
                                            <optgroup label="Backend">
                                                <option value="django">Django</option>
                                                <option value="fastapi">FastAPI</option>
                                                <option value="flask">Flask</option>
                                                <option value="spring">Spring Boot</option>
                                                <option value="express">Express.js</option>
                                                <option value="laravel">Laravel</option>
                                                <option value="rails">Ruby on Rails</option>
                                                <option value="odoo">Odoo</option>
                                            </optgroup>
                                            <optgroup label="Mobile">
                                                <option value="flutter">Flutter</option>
                                                <option value="react_native">React Native</option>
                                                <option value="xamarin">Xamarin</option>
                                            </optgroup>
                                            <option value="other">Other</option>
                                        </select>
                                    </div>
                                    <div class="pc-field">
                                        <label class="pc-label" for="databases">Database</label>
                                        <select class="pc-select" id="databases" name="databases">
                                            <option value="">Select database...</option>
                                            <optgroup label="Relational">
                                                <option value="postgresql">PostgreSQL</option>
                                                <option value="mysql">MySQL</option>
                                                <option value="mssql">SQL Server</option>
                                                <option value="sqlite">SQLite</option>
                                                <option value="oracle">Oracle</option>
                                            </optgroup>
                                            <optgroup label="NoSQL">
                                                <option value="mongodb">MongoDB</option>
                                                <option value="redis">Redis</option>
                                                <option value="cassandra">Cassandra</option>
                                                <option value="firebase">Firebase</option>
                                                <option value="dynamodb">DynamoDB</option>
                                            </optgroup>
                                            <option value="other">Other</option>
                                        </select>
                                    </div>
                                </div>
                            </div>

                            <!-- Section 3: Timeline and Warranty -->
                            <div class="pc-section">
                                <div class="pc-section-label">
                                    <i class="bi bi-calendar-range"></i> Timeline &amp; Warranty </div>
                                <div class="pc-grid-3">
                                    <div class="pc-field">
                                        <label class="pc-label" for="start_date">Start Date <span
                                                class="pc-required">*</span></label>
                                        <input type="date" class="pc-input" id="start_date"
                                            name="start_date" required="required" />
                                    </div>
                                    <div class="pc-field">
                                        <label class="pc-label" for="end_date">Project End Date</label>
                                        <input type="date" class="pc-input" id="end_date"
                                            name="end_date" />
                                    </div>
                                    <div class="pc-field">
                                        <label class="pc-label" for="warranty_months"> Warranty
                                            Period <span class="pc-required">*</span>
                                            <span
                                                class="pc-tooltip"
                                                title="After this period ends, support agents are not responsible for reported issues.">
                                                <i class="bi bi-question-circle-fill"></i>
                                            </span>
                                        </label>
                                        <select class="pc-select" id="warranty_months"
                                            name="warranty_months" required="required">
                                            <option value="">Select period...</option>
                                            <option value="1">1 Month</option>
                                            <option value="3">3 Months</option>
                                            <option value="6">6 Months</option>
                                            <option value="12">12 Months (1 Year)</option>
                                            <option value="18">18 Months</option>
                                            <option value="24">24 Months (2 Years)</option>
                                            <option value="36">36 Months (3 Years)</option>
                                        </select>
                                        <span class="pc-hint" id="warranty_expiry_hint"></span>
                                    </div>
                                </div>

                                <!-- Warranty Notice — shown dynamically -->
                                <div class="pc-warranty-notice" id="warranty_notice"
                                    style="display:none">
                                    <i class="bi bi-shield-check"></i>
                                    <div>
                                        <strong>Warranty Coverage Active</strong>
                                        <span id="warranty_notice_text"></span>
                                    </div>
                                </div>
                            </div>

                            <!-- Section 4: Compliance -->
                            <div class="pc-section">
                                <div class="pc-section-label">
                                    <i class="bi bi-patch-check"></i> Compliance Requirements </div>
                                <div class="pc-compliance-grid">
                                    <label class="pc-compliance-item">
                                        <input type="checkbox" name="compliance_gdpr" value="gdpr" />
                                        <div class="pc-compliance-body">
                                            <span class="pc-compliance-name">GDPR</span>
                                            <span class="pc-compliance-desc">Data Protection</span>
                                        </div>
                                    </label>
                                    <label class="pc-compliance-item">
                                        <input type="checkbox" name="compliance_hipaa" value="hipaa" />
                                        <div class="pc-compliance-body">
                                            <span class="pc-compliance-name">HIPAA</span>
                                            <span class="pc-compliance-desc">Healthcare</span>
                                        </div>
                                    </label>
                                    <label class="pc-compliance-item">
                                        <input type="checkbox" name="compliance_pci_dss"
                                            value="pci_dss" />
                                        <div class="pc-compliance-body">
                                            <span class="pc-compliance-name">PCI DSS</span>
                                            <span class="pc-compliance-desc">Payment Security</span>
                                        </div>
                                    </label>
                                    <label class="pc-compliance-item">
                                        <input type="checkbox" name="compliance_iso27001"
                                            value="iso27001" />
                                        <div class="pc-compliance-body">
                                            <span class="pc-compliance-name">ISO 27001</span>
                                            <span class="pc-compliance-desc">Security Standard</span>
                                        </div>
                                    </label>
                                </div>
                            </div>

                            <!-- Form Actions -->
                            <div class="pc-actions">
                                <button type="reset" class="pc-btn pc-btn-secondary">
                                    <i class="bi bi-arrow-counterclockwise"></i> Reset </button>
                                <button type="submit" class="pc-btn pc-btn-primary">
                                    <i class="bi bi-check2-circle"></i> Save Project </button>
                            </div>

                        </form>
                    </div>
                </div>
            </div>

            <script>
                (function () {
                // Warranty expiry calculator
                const warrantySelect = document.getElementById('warranty_months');
                const endDateInput = document.getElementById('end_date');
                const hint = document.getElementById('warranty_expiry_hint');
                const notice = document.getElementById('warranty_notice');
                const noticeText = document.getElementById('warranty_notice_text');

                function updateWarranty() {
                const months = parseInt(warrantySelect.value);
                const endVal = endDateInput.value;
                if (!months || !endVal) {
                hint.textContent = '';
                notice.style.display = 'none';
                return;
                }
                const base = new Date(endVal);
                base.setMonth(base.getMonth() + months);
                const exp = base.toLocaleDateString('en-US', { year: 'numeric', month: 'long', day:
                'numeric' });
                hint.textContent = 'Coverage expires: ' + exp;
                noticeText.textContent = ' — Support agents are responsible for issues until ' + exp
                + '. Tickets raised after this date may be declined.';
                notice.style.display = 'flex';
                }

                warrantySelect.addEventListener('change', updateWarranty);
                endDateInput.addEventListener('change', updateWarranty);

                // Auto-uppercase project key
                const keyInput = document.getElementById('project_key');
                if (keyInput) {
                keyInput.addEventListener('input', function () {
                const pos = this.selectionStart;
                this.value = this.value.toUpperCase().replace(/[^A-Z0-9-]/g, '');
                this.setSelectionRange(pos, pos);
                });
                }
                })();
            </script>

        </t>
    </template>
</odoo>
            if (targetPage) targetPage.style.display = 'block';
        });
    });

    document.querySelectorAll('.action-card[data-view]').forEach(card => {
        card.addEventListener('click', function(e) {
            e.preventDefault();
            const navLink = document.querySelector(`.nav-link[data-view="${this.getAttribute('data-view')}"]`);
            if (navLink) navLink.click();
        });
    });

    const searchInput = document.querySelector('.search-input');
    if (searchInput) {
        searchInput.addEventListener('input', function() {
            const searchTerm = this.value.toLowerCase();
            document.querySelectorAll('.ticket-row').forEach(ticket => {
                ticket.style.display = ticket.textContent.toLowerCase().includes(searchTerm) ? '' : 'none';
            });
        });
    }

    document.querySelectorAll('.ticket-row').forEach(function(row) {
        row.addEventListener('click', function() {
            const ticketId = this.getAttribute('data-ticket-id');

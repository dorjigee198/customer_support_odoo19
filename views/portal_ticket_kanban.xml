<?xml version="1.0" encoding="utf-8"?>
<odoo>
    <template id="customer_tickets_kanban" name="Customer Tickets Kanban">
        <t t-call="web.layout">
            <t t-set="head">
                <meta name="viewport" content="width=device-width, initial-scale=1.0" />
                <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css"
                    rel="stylesheet" />
                <link
                    href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.10.0/font/bootstrap-icons.css"
                    rel="stylesheet" />
                <link rel="stylesheet" href="/customer_support/static/src/css/portal_dashboard.css" />
                <link rel="stylesheet" href="/customer_support/static/src/css/portal_tickets.css" />
                <link rel="stylesheet"
                    href="/customer_support/static/src/css/portal_dashboard_mobile.css?v=2" />
                <style>
                    #portal-kanban-page { background: #e0f2fe; min-height: 100vh; }
                    .kanban-board { background: transparent; }
                    .kanban-col { background: #f0f9ff; border-color: rgba(12,74,110,0.12); }
                    .view-btn {
                    background: rgba(255,255,255,0.6);
                    border: 1px solid rgba(12,74,110,0.2);
                    color: #0c4a6e;
                    padding: 6px 12px;
                    border-radius: 8px;
                    cursor: pointer;
                    font-weight: 600;
                    transition: all 0.2s;
                    }
                    .view-btn:hover { background: rgba(255,255,255,0.85); border-color:
                    rgba(12,74,110,0.35); }
                    .view-btn.active { background: #0c4a6e; color: #ffffff; border-color: #0c4a6e; }
                </style>
            </t>

            <div class="dashboard-wrapper" id="portal-kanban-page">

                <!-- HEADER — identical to portal_tickets.xml -->
                <header class="dashboard-header">
                    <div class="header-content">
                        <!-- ↓ MOBILE NAV COMPONENT (hamburger + drawer) -->
                        <t t-set="mobile_active_page" t-value="'overview'" />
                        <t t-call="customer_support.portal_mobile_nav_component" />

                        <div class="header-nav">
                            <a href="/customer_support/dashboard" class="nav-link">
                                <i class="bi bi-speedometer2 me-2"></i>Overview</a>
                            <a href="/customer_support/tickets" class="nav-link active">
                                <i class="bi bi-ticket-detailed me-2"></i>Tickets</a>
                            <a href="/customer_support/dashboard#reporting" class="nav-link">
                                <i class="bi bi-graph-up me-2"></i>Reporting</a>
                            <a href="/customer_support/chatbot" class="nav-link">
                                <i class="bi bi-question-circle me-2"></i>FAQ</a>
                        </div>
                        <div class="header-right">
                            <div class="header-actions">
                                <a href="/customer_support/create_ticket" class="btn-new-ticket">
                                    <i class="bi bi-plus-circle me-2"></i>New Ticket</a>
                            </div>
                            <div class="user-profile dropdown">
                                <a class="d-flex align-items-center text-white dropdown-toggle"
                                    href="#" id="userProfileDropdown"
                                    data-bs-toggle="dropdown" aria-expanded="false"
                                    style="text-decoration:none;">
                                    <span class="user-name me-3">
                                        <t t-esc="user.name" />
                                    </span>
                                    <img t-att-src="'/web/image/res.users/%s/avatar_128' % user.id"
                                        alt="User Avatar" class="user-avatar"
                                        onerror="this.src='/web/static/img/avatar_gray.svg'" />
                                </a>
                                <ul class="dropdown-menu dropdown-menu-end"
                                    aria-labelledby="userProfileDropdown">
                                    <li>
                                        <a class="dropdown-item" href="/customer_support/profile">
                                            <i class="bi bi-person me-2"></i>Edit Profile</a>
                                    </li>
                                    <li>
                                        <hr class="dropdown-divider" />
                                    </li>
                                    <li>
                                        <a class="dropdown-item text-danger"
                                            href="/customer_support/logout_manual">
                                            <i class="bi bi-box-arrow-right me-2"></i>Logout</a>
                                    </li>
                                </ul>
                            </div>
                        </div>
                    </div>
                </header>

                <!-- KANBAN CONTENT -->
                <div class="dashboard-content">
                    <!-- Page Header with Toggle -->
                    <div class="page-header">
                        <h1 class="page-title">
                            <i class="bi bi-grid-3x3-gap-fill me-2"></i>My Tickets </h1>
                        <div class="d-flex align-items-center gap-3">
                            <div class="page-stats">
                                <span class="stat-badge">
                                    <i class="bi bi-stack me-1"></i>
                                    <t
                                        t-esc="ticket_counts.get('total', 0)" /> Total </span>
                                <span class="stat-badge">
                                    <i class="bi bi-clock-history me-1"></i>
                                    <t
                                        t-esc="ticket_counts.get('new', 0) + ticket_counts.get('in_progress', 0)" />
                                    Open </span>
                                <span class="stat-badge">
                                    <i class="bi bi-check-circle me-1"></i>
                                    <t
                                        t-esc="ticket_counts.get('resolved', 0)" /> Resolved </span>
                            </div>
                            <div class="view-toggle">
                                <button class="view-btn" id="listViewBtn">
                                    <i class="bi bi-list me-1"></i>List </button>
                                <button class="view-btn active" id="kanbanViewBtn">
                                    <i class="bi bi-grid-3x3-gap me-1"></i>Kanban </button>
                            </div>
                        </div>
                    </div>

                    <!-- Kanban Board -->
                    <div class="kanban-board">
                        <!-- New -->
                        <div class="kanban-col" data-state="new">
                            <div class="kanban-col-header">
                                <span class="kanban-col-title">
                                    <i class="bi bi-circle"></i> New </span>
                                <span class="kanban-col-count" id="count-new">0</span>
                            </div>
                            <div class="kanban-cards" id="col-new">
                                <t t-foreach="tickets" t-as="ticket">
                                    <t t-if="ticket.state == 'new'">
                                        <div class="kanban-card" t-att-data-ticket-id="ticket.id">
                                            <div class="kanban-card-id">
                                                <t t-esc="ticket.name" />
                                            </div>
                                            <div class="kanban-card-subject">
                                                <t t-esc="ticket.subject" />
                                            </div>
                                            <div class="kanban-card-footer">
                                                <t t-set="kp" t-value="ticket.priority or 'low'" />
                                                <span t-att-class="'kanban-priority priority-' + kp">
                                                    <t t-esc="kp.title()" />
                                                </span>
                                            </div>
                                            <div class="kanban-card-focal">
                                                <i class="bi bi-person-fill"></i>
                                                <span>
                                                    <t
                                                        t-esc="ticket.assigned_to.name if ticket.assigned_to else 'Unassigned'" />
                                                </span>
                                            </div>
                                        </div>
                                    </t>
                                </t>
                            </div>
                        </div>
                        <!-- In Progress -->
                        <div class="kanban-col" data-state="in_progress">
                            <div class="kanban-col-header">
                                <span class="kanban-col-title">
                                    <i class="bi bi-arrow-repeat"></i> In Progress </span>
                                <span class="kanban-col-count" id="count-in_progress">0</span>
                            </div>
                            <div class="kanban-cards" id="col-in_progress">
                                <t t-foreach="tickets" t-as="ticket">
                                    <t t-if="ticket.state == 'in_progress'">
                                        <div class="kanban-card" t-att-data-ticket-id="ticket.id">
                                            <div class="kanban-card-id">
                                                <t t-esc="ticket.name" />
                                            </div>
                                            <div class="kanban-card-subject">
                                                <t t-esc="ticket.subject" />
                                            </div>
                                            <div class="kanban-card-footer">
                                                <t t-set="kp" t-value="ticket.priority or 'low'" />
                                                <span t-att-class="'kanban-priority priority-' + kp">
                                                    <t t-esc="kp.title()" />
                                                </span>
                                            </div>
                                            <div class="kanban-card-focal">
                                                <i class="bi bi-person-fill"></i>
                                                <span>
                                                    <t
                                                        t-esc="ticket.assigned_to.name if ticket.assigned_to else 'Unassigned'" />
                                                </span>
                                            </div>
                                        </div>
                                    </t>
                                </t>
                            </div>
                        </div>
                        <!-- Resolved -->
                        <div class="kanban-col" data-state="resolved">
                            <div class="kanban-col-header">
                                <span class="kanban-col-title">
                                    <i class="bi bi-check-circle"></i> Resolved </span>
                                <span class="kanban-col-count" id="count-resolved">0</span>
                            </div>
                            <div class="kanban-cards" id="col-resolved">
                                <t t-foreach="tickets" t-as="ticket">
                                    <t t-if="ticket.state == 'resolved'">
                                        <div class="kanban-card" t-att-data-ticket-id="ticket.id">
                                            <div class="kanban-card-id">
                                                <t t-esc="ticket.name" />
                                            </div>
                                            <div class="kanban-card-subject">
                                                <t t-esc="ticket.subject" />
                                            </div>
                                            <div class="kanban-card-footer">
                                                <t t-set="kp" t-value="ticket.priority or 'low'" />
                                                <span t-att-class="'kanban-priority priority-' + kp">
                                                    <t t-esc="kp.title()" />
                                                </span>
                                            </div>
                                            <div class="kanban-card-focal">
                                                <i class="bi bi-person-fill"></i>
                                                <span>
                                                    <t
                                                        t-esc="ticket.assigned_to.name if ticket.assigned_to else 'Unassigned'" />
                                                </span>
                                            </div>
                                        </div>
                                    </t>
                                </t>
                            </div>
                        </div>
                        <!-- Closed -->
                        <div class="kanban-col" data-state="closed">
                            <div class="kanban-col-header">
                                <span class="kanban-col-title">
                                    <i class="bi bi-x-circle"></i> Closed </span>
                                <span class="kanban-col-count" id="count-closed">0</span>
                            </div>
                            <div class="kanban-cards" id="col-closed">
                                <t t-foreach="tickets" t-as="ticket">
                                    <t t-if="ticket.state == 'closed'">
                                        <div class="kanban-card" t-att-data-ticket-id="ticket.id">
                                            <div class="kanban-card-id">
                                                <t t-esc="ticket.name" />
                                            </div>
                                            <div class="kanban-card-subject">
                                                <t t-esc="ticket.subject" />
                                            </div>
                                            <div class="kanban-card-footer">
                                                <t t-set="kp" t-value="ticket.priority or 'low'" />
                                                <span t-att-class="'kanban-priority priority-' + kp">
                                                    <t t-esc="kp.title()" />
                                                </span>
                                            </div>
                                            <div class="kanban-card-focal">
                                                <i class="bi bi-person-fill"></i>
                                                <span>
                                                    <t
                                                        t-esc="ticket.assigned_to.name if ticket.assigned_to else 'Unassigned'" />
                                                </span>
                                            </div>
                                        </div>
                                    </t>
                                </t>
                            </div>
                        </div>
                    </div>
                </div>
            </div>

            <script
                src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
            <script type="text/javascript">
                //<![CDATA[
                document.addEventListener('DOMContentLoaded', function () {

                    // ── COLUMN COUNTS ─────────────────────────────────────
                    ['new', 'in_progress', 'resolved', 'closed'].forEach(function (state) {
                        var col     = document.getElementById('col-' + state);
                        var countEl = document.getElementById('count-' + state);
                        if (col && countEl) {
                            countEl.textContent = col.querySelectorAll('.kanban-card').length;
                        }
                    });

                    // ── CARD CLICKS ───────────────────────────────────────
                    document.querySelectorAll('.kanban-card').forEach(function (card) {
                        card.addEventListener('click', function () {
                            var id = this.getAttribute('data-ticket-id');
                            if (id) window.location.href = '/customer_support/ticket/' + id;
                        });
                    });

                    // ── TOGGLE BUTTONS ────────────────────────────────────
                    document.getElementById('listViewBtn').addEventListener('click', function () {
                        window.location.href = '/customer_support/tickets';
                    });

                    // kanbanViewBtn is already active — no action needed
                    document.getElementById('kanbanViewBtn').addEventListener('click', function () {
                        window.location.href = '/customer_support/tickets/kanban';
                    });

                });
                //]]>
            </script>
        </t>
    </template>
</odoo>